#!/bin/bash

# Description: Loop Examples

clear -x

# List
for name in Alice Bob Charlie; do
	echo "Hello, $name"
done
echo -e

# Number ranges
for i in {1..5}; do
	echo "Count: $i"
done
echo -e

# Read file line by line
while read -r line ; do
	echo "Line: $line"
done < /etc/hosts
echo -e

# Read file using the colon as a separator
while IFS=: read -r user _ uid gid _ home shell; do
	echo "$user (UID $uid) uses $shell"
done < /etc/passwd
echo -e

# Process files, skip hidden ones
for file in .* *; do
	[[ $file == .* ]] && echo "Hidden file: $file" && continue
	[[ -f "$file" ]] || continue
	echo "Processing: $file"
done

