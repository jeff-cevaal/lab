# create namespace
k create namespace homarr

# set namespace
k config set-context --current --namespace=homarr

# create secret
k create secret generic db-encryption --from-literal=db-encryption-key=$(openssl rand -hex 32)

# add repo
helm repo add homarr-labs https://homarr-labs.github.io/charts/

# update repo
helm repo update

# install homarr
helm install homarr homarr-labs/homarr --values=values.yaml
